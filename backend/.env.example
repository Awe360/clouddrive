# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production
JWT_EXPIRES_IN=7d

# Database Configuration (AWS RDS MySQL / Local MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=@Awoke7012
DB_NAME=clouddrive

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=clouddrive-files-dev-12345

# NOTE: AWS Access Keys are not needed here when running on AWS EC2!
# The backend will automatically fetch credentials from the EC2 IAM Instance Profile.
# For local development, configure your AWS CLI profile (~/.aws/credentials) or use standard AWS credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
